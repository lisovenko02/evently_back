generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  username           String    @unique
  firstName          String
  lastName           String
  avatar             String? // potom pominyat
  points             Float?    @default(0)
  password           String
  hashedRefreshToken String?
  pins               UserPin[]

  events           Event[]
  userEventDetails EventUser[]

  actedHistories     EventUserHistory[] @relation("EventUserHistoryActor")
  eventUserHistories EventUserHistory[]

  eventBans  EventBan[]
  bansIssued EventBan[] @relation("EventBansBy")

  applications         Application[] @relation("SentApplications")
  receivedApplications Application[] @relation("ReceivedApplications")
  actedApplications    Application[] @relation("ActedApplications")

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pin {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  image       String
  rarity      PinRarity
  pointsCost  Float

  owners UserPin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPin {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id])

  pinId Int
  pin   Pin @relation(fields: [pinId], references: [id])

  createdAt DateTime @default(now())
}

model Event {
  id          Int           @id @default(autoincrement())
  title       String        @db.VarChar(120)
  description String        @db.Text
  image       String
  points      Decimal?      @default(30) @db.Decimal(10, 2)
  category    EventCategory
  startTime   DateTime?
  endTime     DateTime?
  isOnline    Boolean       @default(false)

  address   String?  @db.Text
  city      String?  @db.Text
  country   String?  @db.Text
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)

  visibility      EventVisibility @default(OPEN)
  maxParticipants Int?

  organizer   User @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  organizerId Int

  members          EventUser[]        @relation("EventMembers")
  membersHistories EventUserHistory[]

  bans EventBan[]

  applications Application[]
  chats        Chat[]

  board   TaskBoard?
  boardId Int?       @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([startTime])
  @@index([isOnline])
}

model EventUser {
  id      Int   @id @default(autoincrement())
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  Int
  event   Event @relation(fields: [eventId], references: [id], name: "EventMembers", onDelete: Cascade)
  eventId Int
  role    Role  @default(USER)

  createdTasks    Task[]         @relation("TaskCreator")
  assignedToTasks TaskAssignee[] @relation("TaskAssignee")
  assignedByTasks TaskAssignee[] @relation("TaskAssigner")
  createdComments TaskComment[]  @relation("EventUserComments")

  createdChats       Chat[]            @relation("CreatedChats")
  receivedChats      Chat[]            @relation("ReceivedChats")
  chatParticipations ChatParticipant[]
  messages           Message[]         @relation("EventUserMessages")

  notifications Notification[]

  joinedAt DateTime @default(now())

  @@unique([userId, eventId])
  @@index([role])
}

model EventUserHistory {
  id Int @id @default(autoincrement())

  eventUserId Int?

  userId Int
  user   User @relation(fields: [userId], references: [id])

  actorUserId Int?
  actorUser   User? @relation("EventUserHistoryActor", fields: [actorUserId], references: [id])

  eventId Int
  event   Event @relation(fields: [eventId], references: [id])

  status    EventUserHistoryStatus
  reason    String?
  createdAt DateTime               @default(now())

  @@index([eventId, createdAt])
  @@index([eventId, status])
  @@index([eventId, actorUserId])
}

model EventBan {
  id Int @id @default(autoincrement())

  eventId Int
  userId  Int

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  reason String?

  bannedById Int?
  bannedBy   User? @relation("EventBansBy", fields: [bannedById], references: [id])

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model TaskBoard {
  id Int @id @default(autoincrement())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int   @unique

  columns TaskColumn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskColumn {
  id    Int    @id @default(autoincrement())
  title String

  board   TaskBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId Int

  tasks Task[]
  order Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  priority    TaskPriority @default(LOW)
  points      Float?
  dueDate     DateTime?

  column   TaskColumn @relation(fields: [columnId], references: [id])
  columnId Int

  creator   EventUser @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId Int

  assignees TaskAssignee[]
  comments  TaskComment[]
  // assignee   EventUser? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  // assigneeId Int?

  // assignedBy   EventUser? @relation("TaskAssigner", fields: [assignedById], references: [id])
  // assignedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskAssignee {
  id     Int  @id @default(autoincrement())
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId Int

  assignee   EventUser @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId Int

  assignedBy   EventUser? @relation("TaskAssigner", fields: [assignedById], references: [id])
  assignedById Int?

  assignedAt DateTime @default(now())

  @@unique([taskId, assigneeId])
}

model TaskComment {
  id      Int    @id @default(autoincrement())
  content String

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId Int

  author   EventUser @relation("EventUserComments", fields: [authorId], references: [id])
  authorId Int

  createdAt DateTime @default(now())
}

model Chat {
  id      Int      @id @default(autoincrement())
  type    ChatType
  name    String?
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  chatImg String?

  creator   EventUser @relation("CreatedChats", fields: [creatorId], references: [id])
  creatorId Int

  recipient   EventUser? @relation("ReceivedChats", fields: [recipientId], references: [id])
  recipientId Int?

  participants ChatParticipant[]
  messages     Message[]

  lastMessageId Int?      @unique
  lastMessage   Message?  @relation("LastMessage", fields: [lastMessageId], references: [id])
  lastMessageAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, name])
}

model ChatParticipant {
  id     Int  @id @default(autoincrement())
  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId Int

  eventUser   EventUser @relation(fields: [eventUserId], references: [id], onDelete: Cascade)
  eventUserId Int

  joinedAt DateTime @default(now())

  @@unique([chatId, eventUserId])
}

model Message {
  id      Int    @id @default(autoincrement())
  content String

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId Int

  sender   EventUser @relation("EventUserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  senderId Int

  chatLastMessage Chat? @relation("LastMessage")

  attachments MessageAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([senderId])
}

model MessageAttachment {
  id        Int      @id @default(autoincrement())
  fileUrl   String
  fileName  String?
  message   Message  @relation(fields: [messageId], references: [id])
  messageId Int
  createdAt DateTime @default(now())

  @@index([messageId])
}

model Application {
  id Int @id @default(autoincrement())

  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId Int

  sender        User    @relation("SentApplications", fields: [senderId], references: [id])
  senderId      Int
  senderComment String?

  receiver   User? @relation("ReceivedApplications", fields: [receiverId], references: [id])
  receiverId Int?

  decisionBy        User?   @relation("ActedApplications", fields: [decisionById], references: [id])
  decisionById      Int?
  decisionByComment String?

  type              ApplicationType   @default(REQUEST)
  applicationStatus ApplicationStatus @default(PENDING)

  rejectSource       ApplicationRejectSource?
  systemRejectReason ApplicationSystemRejectReason?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId, type, applicationStatus])
  @@index([decisionById])
  @@index([senderId])
  @@index([receiverId])
  @@index([eventId, createdAt])
}

model Notification {
  id      Int              @id @default(autoincrement())
  content String
  isRead  Boolean          @default(false)
  type    NotificationType

  user   User @relation(fields: [userId], references: [id])
  userId Int

  eventUser   EventUser? @relation(fields: [eventUserId], references: [id])
  eventUserId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum EventUserHistoryStatus {
  JOINED
  SELF_LEFT
  KICKED
  BANNED
  UNBANNED
  ROLE_CHANGED
}

enum PinRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ApplicationRejectSource {
  STAFF
  APPLICANT
  SYSTEM
}

enum ApplicationSystemRejectReason {
  CHANGED_VISIBILITY
  EVENT_IS_OVER
}

enum Role {
  USER
  MODERATOR
  ORGANIZER
}

enum EventVisibility {
  OPEN
  CLOSED
  PRIVATE
}

enum NotificationType {
  MESSAGE
  TASK
  EVENT
}

enum EventCategory {
  SPORTS
  MUSIC
  EDUCATION
  BUSINESS
  TECH
  ART
  GAMING
  OTHER
}

enum ApplicationType {
  REQUEST
  INVITE
}

enum ChatType {
  GENERAL
  PRIVATE
  GROUP
}
